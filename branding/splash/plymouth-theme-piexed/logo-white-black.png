<?xml version="1.0" encoding="UTF-8"?>
<!-- Piẻxed OS Boot Logo - White and Black Professional Version -->
<!-- Dell/macOS inspired clean design -->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" width="256" height="256">
  <defs>
    <!-- Clean white gradient for professional look -->
    <linearGradient id="whiteGradient" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#FFFFFF;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#E8E8E8;stop-opacity:1" />
    </linearGradient>
    <!-- Subtle shadow for depth -->
    <filter id="softShadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="0" dy="2" stdDeviation="3" flood-color="#000000" flood-opacity="0.2"/>
    </filter>
  </defs>

  <!-- Dark background for contrast -->
  <rect width="256" height="256" fill="#1A1A2E"/>

  <!-- Main circle - white -->
  <circle cx="128" cy="120" r="70" fill="url(#whiteGradient)" filter="url(#softShadow)"/>

  <!-- Text: PIEXED -->
  <text x="128" y="95"
        font-family="Arial, sans-serif"
        font-size="24"
        font-weight="bold"
        fill="#1A1A2E"
        text-anchor="middle"
        letter-spacing="2">
    PIEXED
  </text>

  <!-- Text: OS -->
  <text x="128" y="120"
        font-family="Arial, sans-serif"
        font-size="18"
        font-weight="normal"
        fill="#1A1A2E"
        text-anchor="middle">
    OS
  </text>

  <!-- Subtle underline accent -->
  <rect x="78" y="140" width="100" height="3" rx="1.5" fill="#E63946"/>

  <!-- Version -->
  <text x="128" y="165"
        font-family="Arial, sans-serif"
        font-size="10"
        fill="#888888"
        text-anchor="middle">
    v1.0.0
  </text>
</svg>